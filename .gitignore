# ==========================================
# macOS 시스템 파일 (Apple 관련)
# ==========================================
.DS_Store           # 폴더의 보기 설정, 아이콘 위치 등 메타데이터
.AppleDouble        # 리소스 포크 데이터를 담은 숨겨진 파일
.LSOverride         # 폴더 레이아웃 설정 관련 파일
.Spotlight-V100     # 스포트라이트 검색 인덱싱 데이터
.Trashes            # 이동식 디스크 등에서 발생하는 휴지통 폴더
.fseventsd          # 파일 시스템 이벤트 로그 데이터

# ==========================================
# Windows 시스템 파일 (MS 관련)
# =   메모장 및 시스템 공통
# ==========================================
Thumbs.db           # 이미지 미리보기 캐시 데이터베이스
desktop.ini         # 폴더 아이콘 및 보기 설정 파일
$RECYCLE.BIN/       # 윈도우용 휴지통 폴더
ehthumbs.db         # 미디어 파일 미리보기 캐시
*.lnk               # 윈도우 전용 바로가기 파일

# ==========================================
# 에디터 및 IDE 관련 (CotEditor, VS Code, EditPlus)
# ==========================================
# CotEditor & 일반 텍스트 에디터
*~                  # 에디터 자동 생성 백업 파일
[._]*               # macOS 임시/숨김 속성 파일들
.bak                # EditPlus 및 일반 에디터 백업 파일
*.tmp               # 프로그램 실행 중 생성되는 임시 파일

# Visual Studio Code
.vscode/            # VS Code 프로젝트별 개인 설정 폴더
*.code-workspace    # VS Code 작업 공간(Workspace) 설정 파일

# ==========================================
# Python 개발 환경 (Python 12 기준)
# ==========================================
__pycache__/        # 컴파일된 바이트코드 캐시
*.py[cod]           # 컴파일된 파이썬 파일들
*$py.class          # Jython 클래스 파일
*.so                # C 확장 모듈 (바이너리)
venv/               # 가상환경 폴더
.env                # 민감한 환경 변수 (보안 필수)
.pytest_cache/      # pytest 실행 캐시
.mypy_cache/        # mypy 타입 체크 캐시
.ipynb_checkpoints/ # 주피터 노트북 자동 저장 포인트
*.log               # 실행 로그 파일

# ==========================================
# Xcode 및 Swift 개발 관련
# ==========================================
build/              # 컴파일 결과물 폴더
*.pbxuser           # Xcode 사용자 개인 설정
*.mode1v3           # Xcode 레이아웃 설정
*.mode2v3           # Xcode 레이아웃 설정
*.perspectivev3     # Xcode 레이아웃 설정
xcuserdata/          # Xcode 사용자별 개인 데이터
*.xccheckout        # 소스 컨트롤 정보
*.moved-aside       # 위치 변경 흔적
DerivedData/        # Xcode 빌드 캐시 (고용량)
*.hmap              # 헤더 맵 파일
*.ipa               # iOS 앱 패키지
*.xcuserstate       # 에디터 창 위치 및 커서 상태 설정
